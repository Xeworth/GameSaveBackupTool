<?xml version="1.0" encoding="UTF-8" ?>
<UserControl
    x:Class="GSBT.WinUI.Views.SandboxStatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:GSBT.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Padding="0,0,16,8"
        Background="{ThemeResource GsbtWindowBgBrush}">
        <StackPanel Spacing="14" MaxWidth="720" HorizontalAlignment="Center">
            <TextBlock
                Text="Simulated states"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,0,0,4" />
            <TextBlock
                Text="Each simulated run is a self-contained session under your profile (GSBT\SandboxSimulation\sessions): dummy saves, settings JSON, and a recommended backup folder named GSBT_Backup_Sim — a small playground disk you can treat as the safe default in prompts without touching your real backups. Simulations apply only to that child process, not this toolbox window. Tab / Shift+Tab; arrow keys in lists; Space toggles checkboxes; Enter activates the focused button; Ctrl+A selects all in text fields."
                TextWrapping="WrapWholeWords"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontSize="12" />

            <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="480">
                <TextBlock
                    Text="Simulate main app"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center" />
                <Button
                    x:Name="SimulateMainAppButton"
                    MinHeight="48"
                    Padding="20,12"
                    HorizontalAlignment="Stretch"
                    Content="Open simulated main window"
                    Click="SimulateMainAppButton_Click"
                    AccessKey="O"
                    ToolTipService.ToolTip="Starts a separate process with dummy games and isolated settings. Alt+O." />
            </StackPanel>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Backup destination" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Pretend there is no default or last-used backup folder so the simulated app must prompt for a path." />
                    <CheckBox
                        x:Name="NoBackupPathCheck"
                        FontSize="12"
                        Content="Simulate missing backup destination (no default / last path)"
                        Checked="NoBackupPathCheck_Changed"
                        Unchecked="NoBackupPathCheck_Changed" />
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="7-Zip in Settings (Compression)" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Overrides whether Settings → Compression reports 7-Zip as installed or not. Backup compression still uses a real 7z.exe when one exists; choosing Not installed surfaces Get 7-Zip like a normal machine without 7-Zip." />
                    <controls:GsbtComboBox
                        x:Name="SevenZipUiModeCombo"
                        MinWidth="280"
                        HorizontalAlignment="Left"
                        SelectionChanged="SevenZipUiModeCombo_SelectionChanged">
                        <ComboBoxItem Content="Follow real install on disk (default)" Tag="auto" />
                        <ComboBoxItem Content="Simulate: 7-Zip is installed" Tag="present" />
                        <ComboBoxItem Content="Simulate: 7-Zip is not installed" Tag="absent" />
                    </controls:GsbtComboBox>
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="First launch" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Pretend the simulated app has never run before so onboarding teaching tips show again." />
                    <CheckBox
                        x:Name="FirstLaunchTipsCheck"
                        FontSize="12"
                        Content="Simulate first app launch (ignore saved “already shown” flags)"
                        Checked="FirstLaunchTipsCheck_Changed"
                        Unchecked="FirstLaunchTipsCheck_Changed" />
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Large dummy games (scan + backup estimate)" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Game B crosses the yellow (Large) threshold (≥ 4 GiB). Game C crosses the red (Suspicious) threshold (≥ 8 GiB). Re-launch the simulated window after changing these." />
                    <CheckBox
                        x:Name="IncludeGameBCheck"
                        FontSize="12"
                        Content="Include Game B (~4 GiB+ simulated size)"
                        Checked="IncludeGameBCheck_Changed"
                        Unchecked="IncludeGameBCheck_Changed" />
                    <CheckBox
                        x:Name="IncludeGameCCheck"
                        FontSize="12"
                        Content="Include Game C (~8 GiB+ simulated size)"
                        Checked="IncludeGameCCheck_Changed"
                        Unchecked="IncludeGameCCheck_Changed" />
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Last backup warnings (simulated window)" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="These buttons send a command to the open simulated main window so you see the same UI as the real app: yellow Last backup + warning toast when files no longer match the backup snapshot, and red + error toast when a game’s retention backups are gone under the default path (the preview clears that row’s last-backup stamp in the sim catalog). Not related to backup-size yellow/red in estimates. Requires an open simulated main window." />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="PreviewYellowButton"
                            MinHeight="32"
                            Padding="12,8"
                            Content="Simulate yellow — snapshot / file drift"
                            Click="PreviewYellowButton_Click"
                            AccessKey="Y"
                            ToolTipService.ToolTip="Drives the simulated window: yellow Last backup column + same toast as live checkpoint drift. Alt+Y." />
                        <Button
                            x:Name="PreviewRedButton"
                            MinHeight="32"
                            Padding="12,8"
                            Content="Simulate red — game backup folder missing"
                            Click="PreviewRedButton_Click"
                            AccessKey="R"
                            ToolTipService.ToolTip="Drives the simulated window: red Last backup + same toast as when backups disappear under the default path (clears last backup in catalog for one row). Alt+R." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                CornerRadius="8"
                BorderBrush="{ThemeResource GsbtBorderBrush}"
                BorderThickness="1"
                Background="{ThemeResource GsbtCardBgBrush}">
                <StackPanel Spacing="6">
                    <TextBlock FontWeight="SemiBold" FontSize="13" Text="Keyboard" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Text="Tab / Shift+Tab move between controls. Arrow keys open combo lists and move inside lists. Space toggles checkboxes and activates the focused button. Enter activates the default button in dialogs. Escape closes dialogs. Ctrl+A selects all text when a text box has focus. Delete removes the focused item where applicable." />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
