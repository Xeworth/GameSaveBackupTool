<?xml version="1.0" encoding="UTF-8" ?>

<ResourceDictionary

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--

      Fluent / Windows 11–aligned neutrals (PowerToys-style: layered grays, system accent for primary actions).

      ThemeDictionaries follow the root Page/Application theme (Light / Dark).

    -->

    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">

            <SolidColorBrush x:Key="GsbtWindowBgBrush" Color="#FFF3F3F3" />

            <SolidColorBrush x:Key="GsbtCardBgBrush" Color="#FFFBFBFB" />

            <SolidColorBrush x:Key="GsbtHeaderStripBrush" Color="#FFF0F0F0" />

            <SolidColorBrush x:Key="GsbtBorderBrush" Color="#FFE0E0E0" />

            <SolidColorBrush x:Key="GsbtBodyTextBrush" Color="#FF1A1A1A" />

            <SolidColorBrush x:Key="GsbtMutedTextBrush" Color="#FF5C5C5C" />

            <SolidColorBrush x:Key="GsbtSecondaryLabelBrush" Color="#FF767676" />

            <SolidColorBrush x:Key="GsbtTableHeaderBgBrush" Color="#FFF5F5F5" />

            <SolidColorBrush x:Key="GsbtTableGridLineBrush" Color="#FFD0D0D0" />

            <SolidColorBrush x:Key="GsbtToolbarStripBrush" Color="#FFF3F3F3" />

            <SolidColorBrush x:Key="GsbtToolbarSeparatorBrush" Color="#FFD0D0D0" />

            <SolidColorBrush x:Key="GsbtToolbarSuccessFillBrush" Color="{ThemeResource SystemAccentColor}" />

            <SolidColorBrush x:Key="GsbtToolbarSuccessBorderBrush" Color="{ThemeResource SystemAccentColorLight2}" />

            <SolidColorBrush x:Key="GsbtToolbarDangerFillBrush" Color="#FFFFEBEE" />

            <SolidColorBrush x:Key="GsbtToolbarDangerBorderBrush" Color="#FFC62828" />

            <SolidColorBrush x:Key="GsbtAccentBrush" Color="{ThemeResource SystemAccentColor}" />

            <SolidColorBrush x:Key="GsbtSettingsTabSelectedBgBrush" Color="#FFE8E8E8" />

            <SolidColorBrush x:Key="GsbtEstimateStatBrush" Color="#FF0B5CAD" />

            <SolidColorBrush x:Key="GsbtEstimateGoodBrush" Color="#FF1B6B3F" />

            <SolidColorBrush x:Key="GsbtEstimateWarnBrush" Color="#FFB25300" />

            <SolidColorBrush x:Key="GsbtEstimateBadBrush" Color="#FFC62828" />

            <SolidColorBrush x:Key="GsbtBenchmarkSuccessTitleBrush" Color="#FF1B6B3F" />

            <SolidColorBrush x:Key="GsbtBenchmarkFailureTitleBrush" Color="#FFB71C1C" />

            <SolidColorBrush x:Key="GsbtMonoBodyBrush" Color="#FF1A1A1A" />

            <SolidColorBrush x:Key="GsbtMonoMutedBrush" Color="#FF5C5C5C" />

        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">

            <SolidColorBrush x:Key="GsbtWindowBgBrush" Color="#FF202020" />

            <SolidColorBrush x:Key="GsbtCardBgBrush" Color="#FF2D2D2D" />

            <SolidColorBrush x:Key="GsbtHeaderStripBrush" Color="#FF323232" />

            <SolidColorBrush x:Key="GsbtBorderBrush" Color="#FF3D3D3D" />

            <SolidColorBrush x:Key="GsbtBodyTextBrush" Color="#FFF3F3F3" />

            <SolidColorBrush x:Key="GsbtMutedTextBrush" Color="#FFC8C8C8" />

            <SolidColorBrush x:Key="GsbtSecondaryLabelBrush" Color="#FF9D9D9D" />

            <SolidColorBrush x:Key="GsbtTableHeaderBgBrush" Color="#FF37373D" />

            <SolidColorBrush x:Key="GsbtTableGridLineBrush" Color="#FF3E3E42" />

            <SolidColorBrush x:Key="GsbtToolbarStripBrush" Color="#FF2B2B2B" />

            <SolidColorBrush x:Key="GsbtToolbarSeparatorBrush" Color="#FF3A3A3A" />

            <SolidColorBrush x:Key="GsbtToolbarSuccessFillBrush" Color="{ThemeResource SystemAccentColor}" />

            <SolidColorBrush x:Key="GsbtToolbarSuccessBorderBrush" Color="{ThemeResource SystemAccentColorLight2}" />

            <SolidColorBrush x:Key="GsbtToolbarDangerFillBrush" Color="#FF442726" />

            <SolidColorBrush x:Key="GsbtToolbarDangerBorderBrush" Color="#FFFF99A4" />

            <SolidColorBrush x:Key="GsbtAccentBrush" Color="{ThemeResource SystemAccentColor}" />

            <SolidColorBrush x:Key="GsbtSettingsTabSelectedBgBrush" Color="#FF353535" />

            <SolidColorBrush x:Key="GsbtEstimateStatBrush" Color="#FF78BEFF" />

            <SolidColorBrush x:Key="GsbtEstimateGoodBrush" Color="#FF81F0AE" />

            <SolidColorBrush x:Key="GsbtEstimateWarnBrush" Color="#FFFFD54F" />

            <SolidColorBrush x:Key="GsbtEstimateBadBrush" Color="#FFEF5350" />

            <SolidColorBrush x:Key="GsbtBenchmarkSuccessTitleBrush" Color="#FF6AC25B" />

            <SolidColorBrush x:Key="GsbtBenchmarkFailureTitleBrush" Color="#FFD46B6B" />

            <SolidColorBrush x:Key="GsbtMonoBodyBrush" Color="#FFD8D8D8" />

            <SolidColorBrush x:Key="GsbtMonoMutedBrush" Color="#FFA8A8A8" />

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>

